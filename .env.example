# ---------------------------------------------------------------------------
# 75 Hard tracker — environment variables
# Copy this file to ".env" and fill in the real values. Never commit ".env".
# ---------------------------------------------------------------------------

# --- Telegram bot ---------------------------------------------------------
# Get this from @BotFather on Telegram (see README).
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# The two allowed Telegram user IDs. Anyone else is rejected by the bot.
# To find your own id, message @userinfobot on Telegram.
AZRA_TELEGRAM_ID=123456789
BERRIN_TELEGRAM_ID=987654321

# --- Anthropic (AI brain, vision for food photos) -------------------------
# Get this from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Vision-capable model used for food/workout estimates and summaries.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Supabase (Postgres + Storage) ----------------------------------------
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=https://your-project.supabase.co
# Service-role key (server-side only — bypasses row level security).
# Used by the bot to read/write. Keep this secret.
SUPABASE_SERVICE_KEY=your-service-role-key-here
# Direct Postgres connection string (used by the Streamlit dashboard).
# Supabase dashboard -> Project settings -> Database -> Connection string.
SUPABASE_DB_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres
# Name of the storage bucket that holds meal + progress photos.
SUPABASE_PHOTO_BUCKET=photos

# --- Location (weather-aware outdoor workout) -----------------------------
# Defaults to a city in the Netherlands. Used with the free Open-Meteo API.
WEATHER_LATITUDE=52.3676
WEATHER_LONGITUDE=4.9041
WEATHER_TIMEZONE=Europe/Amsterdam

# --- Dashboard login ------------------------------------------------------
# Simple per-user PIN to gate the private before/after photo slider.
AZRA_DASHBOARD_PIN=0000
BERRIN_DASHBOARD_PIN=0000
